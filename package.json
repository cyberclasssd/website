	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7",
		"@sveltejs/kit": "^2.60.1",
		"svelte": "^3.54.0",
		"svelte-check": "^3.0.1",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"vite": "^4.3.0",
		"wrangler": "^3"
	},
	"type": "module",
	"dependencies": {
		"autoprefixer": "^10.4.14",
		"postcss": "^8.4.23",
		"tailwindcss": "^3.3.2"
		
	}
}
